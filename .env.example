# Required for AI recommendations, code generation, and verdict classification.
ASPEN_TRIAGE_ANTHROPIC_API_KEY=

# Required for harvesting. Get an API token at:
# https://id.atlassian.com/manage-profile/security/api-tokens
ASPEN_TRIAGE_JIRA_EMAIL=
ASPEN_TRIAGE_JIRA_API_TOKEN=

# Required for code generation and PR creation. Token needs `repo` scope.
ASPEN_TRIAGE_GITHUB_TOKEN=
ASPEN_TRIAGE_GITHUB_FORK_OWNER=brendan1226

# Where to store the SQLite database. Default: ./data/aspen-triage.db
# ASPEN_TRIAGE_DB_PATH=./data/aspen-triage.db

# Embedding model for semantic search.
# ASPEN_TRIAGE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Claude model for classification + recommendations.
# ASPEN_TRIAGE_CLASSIFICATION_MODEL=claude-opus-4-6

# Google OAuth (optional — leave blank to disable auth entirely).
# ASPEN_TRIAGE_GOOGLE_CLIENT_ID=
# ASPEN_TRIAGE_GOOGLE_CLIENT_SECRET=

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ASPEN_TRIAGE_SESSION_SECRET=change-me-in-production

# Comma-separated list of email domains allowed to log in.
# ASPEN_TRIAGE_ALLOWED_DOMAINS=bywatersolutions.com
